{
  "default_profile": "browser-main",
  "profiles": {
    "browser-main": {
      "aliases": ["main", "primary"],
      "config": "~/.human-browser/config.browser-main.json",
      "launchd_label": "com.teramotodaiki.human-browser.browser-main",
      "launchd_plist": "~/Library/LaunchAgents/com.teramotodaiki.human-browser.browser-main.plist",
      "match": {
        "url_hosts": ["mail.example.com", "calendar.example.com"],
        "workspace_regex": ["/Users/.*/projects/main-workspace/"],
        "keywords": ["main", "primary", "workspace-main"]
      }
    },
    "browser-work": {
      "aliases": ["work", "team"],
      "config": "~/.human-browser/config.browser-work.json",
      "launchd_label": "com.teramotodaiki.human-browser.browser-work",
      "launchd_plist": "~/Library/LaunchAgents/com.teramotodaiki.human-browser.browser-work.plist",
      "match": {
        "url_host_regex": ["(^|\\.)internal\\.example\\.com$"],
        "workspace_regex": ["/Users/.*/projects/workspace-work/"],
        "keywords": ["work", "team", "workspace-work"]
      }
    }
  }
}
